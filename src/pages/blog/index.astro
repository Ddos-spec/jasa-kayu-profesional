---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Blog | Jasa Kayu Profesional" description="Tips, trik, dan inspirasi seputar dunia perkayuan dari Jasa Kayu Profesional.">
  <section class="mx-auto max-w-4xl px-4 py-16 md:px-8">
    <h1 class="font-serif text-5xl font-semibold text-wood-brown-800">Blog Jasa Kayu Profesional</h1>
    <p class="mt-4 text-lg text-gray-600">
      Temukan wawasan terbaru seputar perawatan kayu, tren desain interior, dan panduan memilih material terbaik untuk proyek Anda.
    </p>
    <ul class="mt-12 space-y-10">
      {posts.map((post) => (
        <li class="group">
          <a href={`/blog/${post.slug}/`}>
            <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
              <img
                src={post.data.image ?? '/images/blog/blog-1.jpg'}
                alt={post.data.title}
                class="h-48 w-full rounded-lg object-cover sm:h-32 sm:w-48"
                width="300"
                height="200"
                loading="lazy"
              />
              <div>
                <p class="text-sm text-gray-500">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {new Date(post.data.pubDate).toLocaleDateString('id-ID', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                </p>
                <h2 class="mt-2 font-serif text-2xl font-semibold text-wood-brown-800 transition group-hover:text-wood-brown-600">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-gray-600">{post.data.description}</p>
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>
    <div class="mt-16 rounded-3xl border border-wood-brown-100 bg-white p-8 text-center shadow-sm">
      <h2 class="font-serif text-3xl font-semibold text-wood-brown-800">Punya Proyek yang Ingin Didiskusikan?</h2>
      <p class="mt-3 text-base leading-relaxed text-[#4A4A4A]">
        Kalau Anda sudah punya foto area, ukuran kasar, atau referensi material, kirim langsung lewat WhatsApp agar tim kami bantu arahkan layanan yang paling pas.
      </p>
      <div class="mt-6 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="/#layanan" class="rounded-full border border-wood-brown-200 px-6 py-3 text-sm font-semibold text-wood-brown-700 transition hover:bg-wood-brown-50">
          Lihat Layanan
        </a>
        <a href="https://wa.me/6281283135295?text=Halo%20Jasa%20Kayu%20Profesional%2C%20saya%20ingin%20konsultasi%20proyek%20kayu." class="rounded-full bg-wood-brown-700 px-6 py-3 text-sm font-semibold text-white transition hover:bg-wood-brown-800" target="_blank" rel="noopener noreferrer">
          Konsultasi via WhatsApp
        </a>
      </div>
    </div>
  </section>
</Layout>
