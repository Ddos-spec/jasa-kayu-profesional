---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import ImageGallery from '../../components/ImageGallery.astro';

// Get all portfolio entries
const allPortfolios = await getCollection('portfolio');
// Find the specific portfolio based on the slug
export async function getStaticPaths() {
  const portfolios = await getCollection('portfolio');
  return portfolios.map((portfolio) => ({
    params: { slug: portfolio.slug },
    props: { portfolio },
  }));
}

const { portfolio } = Astro.props;
const { Content } = await portfolio.render();

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/portfolio/**/*.{jpeg,jpg,png,gif,svg}');

const fallbackPaths = [
  '/src/assets/images/portfolio/portfolio-1.svg',
  '/src/assets/images/portfolio/portfolio-2.svg',
  '/src/assets/images/portfolio/portfolio-3.svg',
  '/src/assets/images/portfolio/portfolio-4.svg',
  '/src/assets/images/portfolio/portfolio-5.svg',
  '/src/assets/images/portfolio/portfolio-6.svg'
];

const toAssetImagePath = (imagePath?: string, slug?: string) => {
  if (!imagePath) {
    return slug ? `/src/assets/images/portfolio/${slug}.jpg` : undefined;
  }

  if (imagePath.startsWith('/src/assets/images/portfolio/')) {
    return imagePath;
  }

  if (imagePath.startsWith('/images/portfolio/')) {
    return `/src/assets${imagePath}`;
  }

  return imagePath;
};

const resolveImageMetadata = async (imagePath?: string, fallbackPath = fallbackPaths[0]) => {
  if (imagePath && images[imagePath]) {
    return (await images[imagePath]()).default;
  }

  return (await images[fallbackPath]()).default;
};

const imagePath = toAssetImagePath(portfolio.data.image, portfolio.slug);
const mainImage = await resolveImageMetadata(imagePath);
const galleryImages = await Promise.all((portfolio.data.gallery ?? []).map(async (path, index) => ({
  src: await resolveImageMetadata(toAssetImagePath(path), fallbackPaths[(index + 1) % fallbackPaths.length]),
  alt: `${portfolio.data.title} - dokumentasi proyek ${index + 2}`,
  caption: `Dokumentasi proyek ${index + 2}`
})));
const allPortfolioImages = [portfolio.data.image, ...(portfolio.data.gallery ?? [])].filter(Boolean);

// Set SEO variables
const seoTitle = portfolio.data.seoTitle || `${portfolio.data.title} | Portfolio | Jasa Kayu Profesional`;
const seoDescription = portfolio.data.seoDescription || portfolio.data.description;
const keywords = portfolio.data.keywords || 'finishing kayu, portfolio, proyek kayu, lantai kayu, dinding kayu';

// Set canonical URL
const canonical = `https://www.jasakayuprofesional.com/portfolio/${portfolio.slug}`;

const otherProjects = await Promise.all(
  allPortfolios
    .filter(p => p.slug !== portfolio.slug)
    .slice(0, 2)
    .map(async (p, i) => {
      const pImagePath = toAssetImagePath(p.data.image, p.slug);
      const pImage = await resolveImageMetadata(pImagePath, fallbackPaths[i % fallbackPaths.length]);
      return { ...p, pImage };
    })
);
---

<Layout title={seoTitle} description={seoDescription} canonical={canonical}>

<!-- Schema Markup for the specific portfolio item -->
<script type="application/ld+json">
  {JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    "name": portfolio.data.title,
    "alternateName": [seoTitle],
    "description": seoDescription,
    "about": "Finishing kayu profesional",
    "genre": portfolio.data.category,
    "dateCreated": `${portfolio.data.year || new Date().getFullYear()}-01-01`,
    "creator": {
      "@type": "Organization",
      "name": "Jasa Kayu Profesional",
      "url": "https://www.jasakayuprofesional.com/",
      "sameAs": [
        "https://www.facebook.com/jasakayuprofesional",
        "https://www.instagram.com/jasakayuprofesional"
      ],
      "telephone": "+6281283135295",
      "email": "info@jasakayuprofesional.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Jakarta",
        "addressCountry": "ID"
      }
    },
    "image": allPortfolioImages,
    "keywords": keywords,
    "hasPart": allPortfolioImages.map((image) => ({
      "@type": "ImageObject",
      "contentUrl": image
    }))
  })}
</script>

<div class="container mx-auto px-4 py-12 max-w-4xl">
  <div class="mb-8">
    <a href="/#portofolio" class="inline-flex items-center text-wood-brown-700 hover:text-wood-brown-900 font-medium">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4 mr-1" aria-hidden="true">
        <path fill="currentColor" d="M5 12a1 1 0 0 1 1-1h10.586l-3.293-3.293a1 1 0 0 1 1.414-1.414l5 5a1 1 0 0 1 0 1.414l-5 5a1 1 0 0 1-1.414-1.414L16.586 13H6a1 1 0 0 1-1-1Z" />
      </svg>
      Kembali ke Portofolio
    </a>
  </div>
  
  <article class="bg-white rounded-3xl shadow-lg overflow-hidden">
    <div class="h-64 md:h-96 relative">
      <Image
        src={mainImage}
        alt={portfolio.data.title}
        class="w-full h-full object-cover portfolio-detail-image"
        width={800}
        height={600}
        format="webp"
      />
    </div>
    
    <div class="p-8">
      <div class="mb-6">
        <span class="text-xs font-semibold uppercase tracking-wide text-wood-brown-500">{portfolio.data.displayCategory}</span>
        <h1 class="font-serif text-3xl md:text-4xl font-bold text-wood-brown-800 mt-2">{portfolio.data.title}</h1>
        <p class="text-wood-brown-600 mt-3">{portfolio.data.description}</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {portfolio.data.year && <span class="text-sm bg-wood-brown-100 text-wood-brown-800 px-3 py-1 rounded-full">Tahun: {portfolio.data.year}</span>}
          <span class="text-sm bg-wood-brown-100 text-wood-brown-800 px-3 py-1 rounded-full">Kategori: {portfolio.data.displayCategory}</span>
          {portfolio.data.location && <span class="text-sm bg-wood-brown-100 text-wood-brown-800 px-3 py-1 rounded-full">Lokasi: {portfolio.data.location}</span>}
        </div>
      </div>

      {(portfolio.data.location || portfolio.data.address) && (
        <div class="grid gap-4 rounded-2xl border border-wood-brown-100 bg-[#FFFBF2] p-6 md:grid-cols-2">
          {portfolio.data.location && (
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-wood-brown-500">Area Proyek</p>
              <p class="mt-2 text-sm leading-relaxed text-[#4A4A4A]">{portfolio.data.location}</p>
            </div>
          )}
          {portfolio.data.address && (
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-wood-brown-500">Alamat Ringkas</p>
              <p class="mt-2 text-sm leading-relaxed text-[#4A4A4A]">{portfolio.data.address}</p>
            </div>
          )}
        </div>
      )}

      <div class="prose prose-wood-brown mt-8 max-w-none">
        <Content />
      </div>

      {galleryImages.length > 0 && (
        <div class="mt-10">
          <h2 class="font-serif text-2xl font-semibold text-wood-brown-800">Galeri Proyek</h2>
          <p class="mt-3 text-sm leading-relaxed text-[#4A4A4A]">
            Dokumentasi lapangan membantu calon klien melihat proporsi, struktur, dan hasil finishing proyek secara lebih nyata.
          </p>
          <ImageGallery images={galleryImages} columns={2} spacing="md" />
        </div>
      )}

      <div class="mt-10 rounded-3xl bg-wood-brown-800 px-6 py-8 text-white">
        <h2 class="font-serif text-2xl font-semibold">Punya Kebutuhan Kayu Serupa?</h2>
        <p class="mt-3 max-w-2xl text-sm leading-relaxed text-wood-brown-50/90">
          Kirim foto area, ukuran kasar, dan kebutuhan utama Anda lewat WhatsApp. Tim kami bantu arahkan material, scope kerja, dan langkah awal yang paling masuk akal.
        </p>
        <a
          href="/#kontak"
          class="mt-5 inline-flex items-center rounded-full bg-white px-5 py-3 text-sm font-semibold text-wood-brown-800 transition hover:bg-wood-brown-50"
        >
          Konsultasi via WhatsApp
        </a>
      </div>
      
      <div class="mt-10 pt-8 border-t border-wood-brown-100">
        <h3 class="font-serif text-2xl font-semibold text-wood-brown-800 mb-4">Lihat Proyek Lainnya</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {otherProjects.map((p) => (
              <a 
                href={`/portfolio/${p.slug}`} 
                class="block group"
              >
                <div class="overflow-hidden rounded-xl">
                  <Image
                    src={p.pImage}
                    alt={p.data.title}
                    class="w-full h-48 object-cover transition duration-300 group-hover:scale-105 portfolio-detail-image"
                    width={400}
                    height={300}
                    format="webp"
                  />
                </div>
                <h4 class="font-semibold text-wood-brown-800 mt-3 group-hover:text-wood-brown-600">{p.data.title}</h4>
                <p class="text-sm text-wood-brown-600">{p.data.description}</p>
              </a>
            ))}
        </div>
      </div>
    </div>
  </article>
</div>

</Layout>
