---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import Portfolio from '../components/Portfolio.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import SchemaMarkup from '../components/common/SchemaMarkup.astro';
---
<Layout title="Jasa Kayu Profesional | Spesialis Lantai Kayu Jati Solid & Decking" description="Pakar pengerjaan lantai kayu jati solid, kayu merbau solid, kayu sungkai, decking ulin, decking bengkirai, lambersering jati, & pemasangan genteng sirap ulin." canonical="https://www.jasakayuprofesional.com/">
  <SchemaMarkup
    type="Organization"
    name="Jasa Kayu Profesional"
    url="https://www.jasakayuprofesional.com/"
    description="Pakar pengerjaan lantai kayu jati solid, kayu merbau solid, kayu sungkai, decking ulin, decking bengkirai, lambersering jati, & pemasangan genteng sirap ulin."
    logo="/icons/logo.svg"
  />
  <SchemaMarkup
    type="LocalBusiness"
    name="Jasa Kayu Profesional"
    url="https://www.jasakayuprofesional.com/"
    description="Pakar pengerjaan lantai kayu jati solid, kayu merbau solid, kayu sungkai, decking ulin, decking bengkirai, lambersering jati, & pemasangan genteng sirap ulin."
    logo="/icons/logo.svg"
  />
  <Hero />
  <Services />
  <WhyChooseUs />
  <Portfolio />
  <Testimonials />
  <Contact />
  <Footer slot="footer" />
</Layout>
