---
// src/components/analytics/GoogleAnalytics.astro
import { ANALYTICS_CONFIG } from '../../lib/analytics.config';

const { debug = false } = Astro.props;
const { measurementId } = ANALYTICS_CONFIG.ga4;
const baseConfig = debug ? { debug_mode: true } : undefined;
const initScript = [
  'window.dataLayer = window.dataLayer || [];',
  'function gtag(){dataLayer.push(arguments);}',
  "gtag('js', new Date());",
  baseConfig
    ? `gtag('config', ${JSON.stringify(measurementId)}, ${JSON.stringify(baseConfig)});`
    : `gtag('config', ${JSON.stringify(measurementId)});`
].join('\n');
const pageViewScript = [
  "gtag('config', " + JSON.stringify(measurementId) + ', {',
  '  page_title: document.title,',
  '  page_location: window.location.href,',
  '  page_path: window.location.pathname,',
  '});'
].join('\n');
---

{measurementId ? (
  <>
    {/* Google Tag Manager script */}
    <script type="text/partytown" async src={`https://www.googletagmanager.com/gtag/js?id=${measurementId}`} />
    <script type="text/partytown" is:inline set:html={initScript} />
    
    {/* Enhanced measurement */}
    <script type="text/partytown" is:inline set:html={pageViewScript} />
  </>
) : null}
