---
import LinkButton from '../components/common/LinkButton.astro';

const services = [
  {
    title: 'Lantai Kayu Jati & Merbau Solid',
    slug: 'lantai-kayu-premium',
    icon: '/icons/flooring.svg',
    description:
      'Spesialis pemasangan lantai kayu jati solid dan merbau solid dengan standar presisi tinggi. Kami memastikan setiap bilah kayu melewati proses kiln dry yang sempurna sehingga bebas dari muai-susut berlebih. Kayu jati menawarkan keindahan serat yang tak tertandingi dan ketahanan luar biasa, sementara kayu merbau dikenal dengan kekerasan dan warna kemerahan yang eksotis. Teknik pemasangan profesional kami memastikan hasil akhir yang rapat, rata, dan elegan untuk hunian mewah Anda.',
    highlights: [
      'Lantai kayu jati solid grade A untuk keindahan natural',
      'Kayu merbau solid dengan ketahanan dan tingkat kekerasan tinggi',
      'Pemasangan presisi anti-muai dan susut',
      'Finishing premium tahan gores dan anti rayap'
    ]
  },
  {
    title: 'Kayu Sungkai Interior',
    slug: 'dinding-kayu-dan-wall-cladding',
    icon: '/icons/wall.svg',
    description:
      'Kayu sungkai sangat diminati untuk gaya interior cerah, minimalis, dan kontemporer. Kami menyediakan panel kayu sungkai untuk kebutuhan lantai, dinding, maupun elemen arsitektural lainnya. Serat kayu sungkai yang tegas dan warnanya yang terang memberikan ilusi ruang yang lebih luas dan bersih. Pengerjaan dilakukan oleh tukang spesialis untuk menjaga tekstur alami kayu sungkai tetap menonjol dengan finishing natural yang sempurna.',
    highlights: [
      'Pilihan utama untuk desain interior minimalis dan Japandi',
      'Serat kayu eksotis dengan warna cerah yang elegan',
      'Pemasangan panel dinding dan elemen interior',
      'Finishing natural atau white-wash'
    ]
  },
  {
    title: 'Decking Ulin & Bengkirai',
    slug: 'pergola-decking-outdoor',
    icon: '/icons/pergola.svg',
    description:
      'Solusi terbaik untuk area outdoor, kolam renang, dan teras menggunakan decking ulin dan decking bengkirai. Kayu ulin (kayu besi) adalah material legendaris yang semakin kuat saat terkena air, sementara bengkirai menawarkan daya tahan cuaca ekstrem dengan harga yang sangat sepadan. Instalasi decking kami menggunakan sistem rangka yang kuat, anti lapuk, dan finishing outdoor khusus yang melindunginya dari sinar UV dan hujan tropis.',
    highlights: [
      'Decking kayu ulin (kayu besi) untuk area kolam renang dan outdoor',
      'Decking bengkirai tahan cuaca dengan ketahanan jangka panjang',
      'Instalasi dengan sekrup khusus anti karat',
      'Coating khusus eksterior tahan sinar UV dan air'
    ]
  },
  {
    title: 'Lambersering Jati (Plafon & Dinding)',
    slug: 'plafon-kayu-ceiling',
    icon: '/icons/ceiling.svg',
    description:
      'Hadirkan kemewahan klasik dan nuansa hangat melalui pemasangan lambersering jati untuk plafon (ceiling) dan pelapis dinding. Lambersering dari kayu jati solid tidak hanya menaikkan nilai estetika ruangan tetapi juga memberikan fungsi insulasi akustik dan termal yang baik. Kami sangat memperhatikan detail sambungan dan kerataan permukaan untuk menciptakan focal point ruangan yang memukau.',
    highlights: [
      'Plafon lambersering jati solid kualitas ekspor',
      'Pelapis dinding elegan penambah nilai estetika',
      'Insulasi suhu dan suara alami untuk ruangan',
      'Pemilihan serat kayu senada untuk hasil akhir yang harmonis'
    ]
  },
  {
    title: 'Pemasangan Genteng Sirap Ulin',
    slug: 'genteng-sirap-ulin',
    icon: '/icons/furniture.svg',
    description:
      'Kami melayani jasa pemasangan genteng sirap dari kayu ulin asli. Atap sirap ulin memberikan karakter arsitektur tropis yang unik, sejuk, dan menyatu dengan alam. Dengan sifat kayu ulin yang sangat kuat terhadap air dan perubahan cuaca, atap sirap mampu bertahan hingga puluhan tahun. Pemasangan dilakukan dengan teknik tumpang tindih presisi tinggi untuk memastikan atap 100% anti bocor.',
    highlights: [
      'Atap sirap kayu ulin asli Kalimantan',
      'Daya tahan puluhan tahun terhadap cuaca tropis',
      'Teknik pemasangan anti bocor dan rapi',
      'Tampilan arsitektur tropis eksotis dan eksklusif'
    ]
  }
];
---
<section id="layanan" class="section-anchor bg-[#FFF8DC] py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4 md:px-8">
    <div class="flex flex-col items-center text-center">
      <span class="badge bg-wood-brown-100 text-wood-brown-800">Spesialisasi Kami</span>
      <h2 class="mt-5 font-serif text-4xl font-semibold text-wood-brown-800 md:text-5xl">Keahlian Jasa Kayu Profesional</h2>
      <p class="mt-4 max-w-3xl text-lg leading-relaxed text-[#4A4A4A]">
        Kami adalah pakar yang berfokus pada pengerjaan kayu kualitas atas. Spesialisasi kami meliputi instalasi lantai kayu jati solid, kayu merbau solid, kayu sungkai, decking ulin, decking bengkirai, lambersering jati, hingga pemasangan genteng sirap ulin. Tim kami menjamin hasil yang sempurna, awet, dan bernilai seni tinggi.
      </p>
    </div>
    <div class="mt-16 grid gap-8 md:grid-cols-2">
      {services.map((service) => (
        <article class="card-hover flex h-full flex-col rounded-3xl border border-wood-brown-100 bg-[#FFFAF0] p-8 shadow-elegant">
          <div class="flex items-center gap-4">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-wood-brown-100">
              <img src={service.icon} alt={`Ikon ${service.title}`} class="h-8 w-8" loading="lazy" />
            </div>
            <h3 class="font-serif text-2xl font-semibold text-wood-brown-800">{service.title}</h3>
          </div>
          <p class="mt-6 flex-1 text-base leading-relaxed text-[#4A4A4A]">
            {service.description}
          </p>
          <ul class="mt-6 space-y-3 text-sm text-[#4A4A4A]">
            {service.highlights.map((item, index) => (
              <li class="flex items-start gap-3" key={`${service.title}-${index}`}>
                <span class="mt-1 inline-flex h-2.5 w-2.5 rounded-full bg-wood-brown-700"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <LinkButton
            variant="secondary"
            size="md"
            class="mt-6 self-start"
            href={`#kontak`}
            aria-label={`Konsultasi layanan ${service.title}`}
          >
            Konsultasi {service.title}
          </LinkButton>
        </article>
      ))}
    </div>
  </div>
</section>
