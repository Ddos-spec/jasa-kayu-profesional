---
import { type CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title} description={post.data.description} canonical={`https://www.jasakayuprofesional.com/blog/${post.slug}/`}>
  <article class="mx-auto max-w-3xl px-4 py-16 md:px-8">
    <a href="/blog" class="text-sm font-semibold text-wood-brown-700 hover:text-wood-brown-900">
      &larr; Kembali ke Blog
    </a>
    <h1 class="mt-6 font-serif text-4xl font-semibold text-wood-brown-800 sm:text-5xl">
      {post.data.title}
    </h1>
    <p class="mt-4 text-gray-500">
      Diterbitkan pada
      <time datetime={post.data.pubDate.toISOString()}>
        {new Date(post.data.pubDate).toLocaleDateString('id-ID', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
      </time>
    </p>
    <img
      src={post.data.image ?? '/images/blog/blog-1.jpg'}
      alt={post.data.title}
      class="mt-8 h-80 w-full rounded-lg object-cover"
      width="800"
      height="400"
      loading="eager"
    />
    <div class="prose mt-8 max-w-none">
      <Content />
    </div>
    <div class="mt-12 rounded-3xl border border-wood-brown-100 bg-[#FFFBF2] p-8 shadow-sm">
      <h2 class="font-serif text-2xl font-semibold text-wood-brown-800">Lanjut ke Konsultasi Proyek</h2>
      <p class="mt-3 text-base leading-relaxed text-[#4A4A4A]">
        Kalau artikel ini sudah sesuai dengan kebutuhan Anda, langkah berikutnya paling cepat adalah kirim foto area, lokasi proyek, dan gambaran kebutuhan melalui WhatsApp.
      </p>
      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <a href="/#layanan" class="inline-flex items-center justify-center rounded-full border border-wood-brown-200 px-6 py-3 text-sm font-semibold text-wood-brown-700 transition hover:bg-wood-brown-50">
          Lihat Layanan
        </a>
        <a href="https://wa.me/6281283135295?text=Halo%20Jasa%20Kayu%20Profesional%2C%20saya%20ingin%20diskusi%20proyek%20kayu." class="inline-flex items-center justify-center rounded-full bg-wood-brown-700 px-6 py-3 text-sm font-semibold text-white transition hover:bg-wood-brown-800" target="_blank" rel="noopener noreferrer">
          Konsultasi via WhatsApp
        </a>
      </div>
    </div>
  </article>
</Layout>
